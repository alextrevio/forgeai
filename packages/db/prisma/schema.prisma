generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum ProjectStatus {
  ACTIVE
  BUILDING
  DEPLOYING
  DEPLOYED
  DRAFT
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MemberRole {
  viewer
  editor
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  password        String
  plan            Plan            @default(FREE)
  creditsUsed     Int             @default(0)
  creditsLimit    Int             @default(50)
  githubToken     String?
  githubUsername   String?
  supabaseUrl     String?
  supabaseKey     String?
  settings        Json?
  projects        Project[]
  memberships     ProjectMember[]
  notifications   Notification[]
  refreshTokens   RefreshToken[]
  apiKeys         ApiKey[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Project {
  id                 String        @id @default(cuid())
  name               String
  description        String?
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           Message[]
  snapshots          Snapshot[]
  members            ProjectMember[]
  sandboxId          String?
  deployUrl          String?
  subdomain          String?       @unique
  githubRepo         String?
  supabaseProjectId  String?
  status             ProjectStatus @default(ACTIVE)
  framework          String        @default("react-vite")
  settings           Json?
  customInstructions String?       @db.Text
  template           String?
  forkedFrom         String?
  thumbnail          String?       @db.Text
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // ─── Arya Engine fields ───
  engineStatus    String   @default("idle") // idle, planning, running, completed, failed, paused
  planSteps       Json?    // Array of orchestrator plan steps
  memoryContext   Json?    // Persistent project memory
  totalTokensUsed Int      @default(0)
  estimatedCost   Float    @default(0)
  activeAgents    Json?    // Currently active agents: [{ type: "coder", taskId: "..." }]

  tasks           Task[]
  activityLogs    ActivityLog[]

  @@index([userId])
}

model ProjectMember {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      MemberRole @default(viewer)
  invitedAt DateTime   @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Message {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role            MessageRole
  content         String      @db.Text
  messageType     String?
  plan            Json?
  codeChanges     Json?
  tokensUsed      Int?
  creditsConsumed Int         @default(0)
  model           String?
  createdAt       DateTime    @default(now())

  @@index([projectId])
}

model Snapshot {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  files     Json
  createdAt DateTime @default(now())

  @@index([projectId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  projectId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
}

// ─── Arya Engine: Task orchestration ───

model Task {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTaskId  String?
  parentTask    Task?    @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks      Task[]   @relation("SubTasks")

  agentType     String   // coder, research, designer, analyst, writer, deploy, qa, planner
  modelUsed     String?  // opus, sonnet, haiku, gpt4o, gemini, etc
  status        String   @default("pending") // pending, running, completed, failed, cancelled

  title         String   // "Investigando competidores", "Creando componentes React"
  description   String?  @db.Text
  inputPrompt   String?  @db.Text
  outputResult  Json?    // Flexible result (text, code, files, etc)

  tokensUsed    Int      @default(0)
  durationMs    Int?
  errorMessage  String?  @db.Text

  order         Int      @default(0)

  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  activityLogs  ActivityLog[]

  @@index([projectId])
  @@index([parentTaskId])
  @@index([projectId, status])
}

// ─── Arya Engine: Real-time activity feed ───

model ActivityLog {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  type        String   // plan_step, file_change, terminal_cmd, agent_message, thinking, error, agent_spawn, agent_complete
  agentType   String?  // coder, research, designer, etc

  content     Json     // Flexible payload per type
  // file_change: { action: "create"|"modify"|"delete", path: "src/...", diff: "..." }
  // terminal_cmd: { command: "npm install", output: "...", exitCode: 0 }
  // thinking: { message: "Analizando la estructura..." }
  // plan_step: { step: "Crear componentes", status: "running" }
  // agent_spawn: { agentType: "coder", taskTitle: "..." }

  timestamp   DateTime @default(now())

  @@index([projectId, timestamp])
  @@index([taskId])
}
