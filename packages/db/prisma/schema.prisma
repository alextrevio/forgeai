generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum ProjectStatus {
  ACTIVE
  BUILDING
  DEPLOYING
  DEPLOYED
  DRAFT
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MemberRole {
  viewer
  editor
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  password        String
  plan            Plan            @default(FREE)
  creditsUsed     Int             @default(0)
  creditsLimit    Int             @default(50)
  githubToken     String?
  githubUsername   String?
  supabaseUrl     String?
  supabaseKey     String?
  settings        Json?
  projects        Project[]
  memberships     ProjectMember[]
  notifications   Notification[]
  refreshTokens   RefreshToken[]
  apiKeys         ApiKey[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Project {
  id                 String        @id @default(cuid())
  name               String
  description        String?
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           Message[]
  snapshots          Snapshot[]
  members            ProjectMember[]
  sandboxId          String?
  deployUrl          String?
  subdomain          String?       @unique
  githubRepo         String?
  supabaseProjectId  String?
  status             ProjectStatus @default(ACTIVE)
  framework          String        @default("react-vite")
  settings           Json?
  customInstructions String?       @db.Text
  template           String?
  forkedFrom         String?
  thumbnail          String?       @db.Text
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([userId])
}

model ProjectMember {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      MemberRole @default(viewer)
  invitedAt DateTime   @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Message {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role            MessageRole
  content         String      @db.Text
  messageType     String?
  plan            Json?
  codeChanges     Json?
  tokensUsed      Int?
  creditsConsumed Int         @default(0)
  model           String?
  createdAt       DateTime    @default(now())

  @@index([projectId])
}

model Snapshot {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  files     Json
  createdAt DateTime @default(now())

  @@index([projectId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  projectId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
}
