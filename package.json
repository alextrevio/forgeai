{
  "name": "forgeai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @forgeai/db generate",
    "db:push": "pnpm --filter @forgeai/db push",
    "db:migrate": "pnpm --filter @forgeai/db migrate",
    "dev:api": "pnpm --filter @forgeai/api dev",
    "dev:web": "pnpm --filter @forgeai/web dev",
    "build:packages": "pnpm --filter @forgeai/shared build && pnpm --filter @forgeai/db generate && pnpm --filter @forgeai/sandbox-manager build && pnpm --filter @forgeai/agents build",
    "db:studio": "pnpm --filter @forgeai/db studio",
    "clean": "turbo clean && rm -rf node_modules",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
