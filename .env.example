# ── ForgeAI Environment Variables ─────────────────────────
# Copy this file to .env and fill in the values

# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://forgeai:changeme@localhost:5432/forgeai?schema=public"

# ── Authentication ────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="your-jwt-secret-at-least-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-at-least-32-chars"

# ── Encryption ────────────────────────────────────────────
# Used for encrypting sensitive fields (API keys, tokens) at rest
# Generate with: openssl rand -hex 16  (produces 32 hex chars)
ENCRYPTION_KEY="your-32-character-encryption-key"

# ── Application URLs ──────────────────────────────────────
APP_URL="http://localhost:3000"
API_URL="http://localhost:8000"

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000"

# ── Server ────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── Logging ───────────────────────────────────────────────
# Options: fatal, error, warn, info, debug, trace
LOG_LEVEL=debug

# ── Sandbox ───────────────────────────────────────────────
SANDBOXES_DIR=.sandboxes
SANDBOX_TTL_MINUTES=30

# ── AI Providers (optional — users can also set their own) ─
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ── Web Search (optional — enables Research Agent web search) ─
# Get a key from https://serper.dev (preferred) or https://tavily.com
# If neither is set, Research Agent uses LLM knowledge only
SERPER_API_KEY=""
TAVILY_API_KEY=""

# ── GitHub OAuth (optional) ───────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Redis (optional, used for rate limiting in production) ─
# REDIS_URL="redis://localhost:6379"

# ── PostHog (optional — analytics & user tracking) ───────
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# POSTHOG_API_KEY=""
# POSTHOG_HOST="https://us.i.posthog.com"

# ── Sentry (optional — error monitoring) ─────────────────
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT_API=""
# SENTRY_PROJECT_WEB=""

# ── Next.js (frontend) ───────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:8000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:8000"
